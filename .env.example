# Copy this file to `.env` and fill in your key.
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional tuning (defaults shown)
# Max concurrent requests to OpenRouter (keeps you under free-tier rate limits)
OPENROUTER_MAX_CONCURRENCY=3
# Per-request timeout in seconds
OPENROUTER_TIMEOUT=90
# Optional: sent to OpenRouter for attribution (nice-to-have, not required)
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_TITLE=AI Council
